# Grant Opportunity Matcher — Environment Variables
# Copy this file to .env and fill in your values.

# ── AI Scoring Provider (pick one) ───────────────────────────────────────────
# The app auto-detects whichever key is present. Priority: Anthropic → OpenAI → Groq → Ollama.

# Anthropic Claude (default — recommended)
ANTHROPIC_API_KEY=your_key_here

# OpenAI
# OPENAI_API_KEY=your_key_here

# Groq (fast, free tier available)
# GROQ_API_KEY=your_key_here

# Ollama (local, no key needed — just set the base URL)
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ── Optional Overrides ────────────────────────────────────────────────────────

# Force a specific provider instead of auto-detecting:
# AI_PROVIDER=anthropic   # anthropic | openai | groq | ollama

# Override the default model for the selected provider:
# AI_MODEL=claude-haiku-4-5-20251001

# Custom base URL for any OpenAI-compatible endpoint:
# OPENAI_BASE_URL=https://your-endpoint.example.com/v1
